# =============================================================================
# Palworld Server - Configuração (Fase 1)
# Instância: Oracle Cloud Ubuntu ARM64 (2 OCPU / 12GB RAM) - box64
# Otimizado para: 5 jogadores no pico
# =============================================================================
# Deposite este arquivo como /opt/palworld/.env na instância e EDITE
# os valores abaixo — especialmente o ADMIN_PASSWORD.
#
# IMPORTANTE: Este arquivo NÃO deve conter senhas reais.
#             O deploy com este template NÃO funciona até preencher
#             o ADMIN_PASSWORD no .env real da instância.
# ====================================================================================

# ---- Identidade do servidor ------------------------------------------------
SERVER_NAME="Joga10 Pal Server"
SERVER_DESCRIPTION=""
SERVER_PASSWORD="123"
ADMIN_PASSWORD="trocar-por-senha-forte"

# Apenas amigos conectam por IP/DNS - não aparece na lista pública de servidores
COMMUNITY="false"

# Timezone
TZ="America/Sao_Paulo"

# ---- Recursos e portas ------------------------------------------------------
# Usuário/grupo do container (padrão da imagem)
PUID=1000
PGID=1000

# Porta do jogo (UDP)
PORT=8211
# Max de jogadores - folga sobre pico de 5
PLAYERS=8
# Query port Steam (UDP)
QUERY_PORT=27015

# IP público vazio = autodetecção (IP é efêmero na Oracle Cloud;
# o acesso dos amigos é via DNS dinâmico DuckDNS - ver duckdns-updater.sh)
PUBLIC_IP=

# ---- REST API (usada pelo auto-sleep manager - Fase 2) ---------------------
REST_API_ENABLED="true"
REST_API_PORT=8212

# ---- RCON (administração local + shutdown gracioso) -------------------------
RCON_ENABLED="true"
RCON_PORT=25575

# ---- Threading (aproveitar 2 OCPUs) ----------------------------------------
ENABLE_PERF_THREADING_ARGS="true"
WORKER_THREADS_SERVER=2
MULTITHREADING="true"

# ---- Backup automático ------------------------------------------------------
BACKUP_ENABLED="true"
BACKUP_CRON_EXPRESSION="0 4 * * *"
DELETE_OLD_BACKUPS="true"
OLD_BACKUP_DAYS=7

# ---- Atualizações -----------------------------------------------------------
UPDATE_ON_BOOT="true"
AUTO_UPDATE_ENABLED="true"

# ---- Box64 (emulação ARM64) -------------------------------------------------
BOX64_DYNAREC_STRONGMEM=1
BOX64_DYNAREC_BIGBLOCK=1
ARM64_DEVICE="generic"

# ---- Gerenciamento de configuração -----------------------------------------
# false = imagem gera PalWorldSettings.ini automaticamente a partir das ENV vars
DISABLE_GENERATE_SETTINGS="false"

# =============================================================================
# CONFIGURAÇÕES DO JOGO
#
# Combinação do seu PalWorldSettings.ini atual com otimizações para o free tier
# (2 OCPU / 12GB RAM). A imagem Docker converte estas variáveis para o .ini.
#
# VALORES PRESERVADOS DO SEU .ini (que diferem do padrão):
#   BaseCampWorkerMaxNum=18, BaseCampMaxNumInGuild=6, CoopPlayerMaxNum=5
#
# OTIMIZAÇÕES PARA FREE TIER (reduzem CPU/RAM):
#   PAL_SPAWN_NUM_RATE=0.7, DROP_ITEM_MAX_NUM=1000, etc.
#
# Para ver todas as variáveis disponíveis, consulte:
#   https://palworld-server-docker.loef.dev/getting-started/configuration/game-settings
# =============================================================================

# ---- Otimizações para free tier (2 OCPU / 12GB RAM) ------------------------
PAL_SPAWN_NUM_RATE=0.7
DROP_ITEM_MAX_NUM=1000
DROP_ITEM_ALIVE_MAX_HOURS=0.5
SUPPLY_DROP_SPAN=360
SERVER_REPLICATE_PAWN_CULL_DISTANCE=10000.0
AUTO_SAVE_SPAN=60.0

# ---- Base e guilda (mantidos do seu .ini) -----------------------------------
BASE_CAMP_WORKER_MAX_NUM=18
BASE_CAMP_MAX_NUM_IN_GUILD=6
COOP_PLAYER_MAX_NUM=5

# ---- Gameplay (mantidos do seu .ini) ----------------------------------------
CROSSPLAY_PLATFORMS="(Steam,Xbox,PS5,Mac)"
DEATH_PENALTY="Item"
GUILD_PLAYER_MAX_NUM=20
WORK_SPEED_RATE=1.0
EXP_RATE=1.0
PAL_CAPTURE_RATE=1.0
ENEMY_DROP_ITEM_RATE=1.0
ITEM_WEIGHT_RATE=1.0
bALLOW_CLIENT_MOD="true"
bENABLE_NON_LOGIN_PENALTY="true"
bENABLE_FAST_TRAVEL="true"
bENABLE_INVADER_ENEMY="true"
bHARDCORE="false"
bPAL_LOST="false"
bIS_PVP="false"

# ---- Log de jogadores ------------------------------------------------------
ENABLE_PLAYER_LOGGING="true"
PLAYER_LOGGING_POLL_PERIOD=5
IS_SHOW_JOIN_LEFT_MESSAGES="true"

# ---- Discord (opcional - preencha se quiser notificações) -------------------
# DISCORD_WEBHOOK_URL=""
# DISCORD_PRE_SHUTDOWN_MESSAGE="Servidor vai desligar (auto-sleep)..."
# DISCORD_POST_SHUTDOWN_MESSAGE="Servidor desligado. Conecte novamente para acordar."
