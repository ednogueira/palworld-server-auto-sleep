# Modo de operacao: docker
MANAGEMENT_MODE=docker
DOCKER_CONTAINER_NAME=palworld-server

# UDP wake listener
GAME_HOST=0.0.0.0
GAME_PORT=8211

# REST API do palworld-server (acessivel via host porque manager usa network_mode host)
REST_API_HOST=127.0.0.1
REST_API_PORT=8212
REST_API_USERNAME=admin
REST_API_PASSWORD=trocar-por-senha-forte

# Politica de idle
PLAYER_CHECK_INTERVAL_SECONDS=60
EMPTY_SERVER_TIMEOUT_MINUTES=10
SERVER_STARTUP_TIMEOUT_SECONDS=300
SERVER_SHUTDOWN_TIMEOUT_SECONDS=90
WAKE_COOLDOWN_SECONDS=30

# Logging
LOG_LEVEL=info
