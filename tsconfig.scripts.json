{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-scripts",
    "types": ["node"]
  },
  "include": ["scripts/test-scenarios/**/*.ts", "src/**/*.ts"],
  "exclude": ["dist", "dist-scripts", "node_modules", "tests"]
}
