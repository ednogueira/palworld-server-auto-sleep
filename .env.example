# Modo de operacao: native-windows (Windows local) ou docker (Linux/cloud)
MANAGEMENT_MODE=native-windows

PALSERVER_EXE_PATH=C:\Program Files (x86)\Steam\steamapps\common\PalServer\PalServer.exe
PALSERVER_WORKING_DIRECTORY=C:\Program Files (x86)\Steam\steamapps\common\PalServer
PALSERVER_ARGUMENTS=-useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS
PALSERVER_PROCESS_NAME=PalServer-Win64-Test-Cmd.exe

GAME_HOST=0.0.0.0
GAME_PORT=8211

REST_API_HOST=127.0.0.1
REST_API_PORT=8212
REST_API_USERNAME=admin
REST_API_PASSWORD=trocar-por-senha-forte

PLAYER_CHECK_INTERVAL_SECONDS=60
EMPTY_SERVER_TIMEOUT_MINUTES=10
SERVER_STARTUP_TIMEOUT_SECONDS=180
SERVER_SHUTDOWN_TIMEOUT_SECONDS=240
WAKE_COOLDOWN_SECONDS=30

# Shutdown seguro (protecao contra corrupcao de save)
SAVE_POST_DELAY_SECONDS=20
SHUTDOWN_API_WAITTIME_SECONDS=30
REST_API_SAVE_TIMEOUT_SECONDS=60
PRE_SHUTDOWN_BACKUP_ENABLED=true
PRE_SHUTDOWN_BACKUP_MAX_WAIT_SECONDS=120

# Timezone (afeta logs e timestamps de backup)
TZ=America/Sao_Paulo

LOG_LEVEL=info
