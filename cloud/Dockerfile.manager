FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json ./
RUN npm install
COPY src/ src/
COPY tsconfig.json ./
RUN npm run build

FROM node:22-alpine
RUN apk add --no-cache docker-cli tzdata
ENV TZ=America/Sao_Paulo
WORKDIR /app
COPY --from=builder /app/dist/ dist/
COPY --from=builder /app/node_modules/ node_modules/
COPY package.json ./
CMD ["node", "dist/index.js"]
